{
  "name": "polymongo",
  "version": "1.3.0",
  "description": "Adaptive Multi-Database Wrapper for Mongoose with automatic connection management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rimraf dist && tsup src/index.ts --format cjs --dts --minify --sourcemap --external mongoose,mongodb,winston",
    "build:dev": "tsup src/index.ts --format cjs --dts --watch",
    "prepublishOnly": "npm run build",
    "test": "node test/index.js",
    "exServer": "nodemon examples/server.js",
    "format": "prettier --write src/**/*.ts"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mongoose",
    "mongodb",
    "multi-database",
    "connection-pool",
    "database-wrapper",
    "polymongo"
  ],
  "author": "Krishnesh Mishra",
  "license": "MIT",
  "dependencies": {
    "mongodb": "^6.20.0",
    "mongoose": "^8.19.1",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/mongoose": "^5.11.97",
    "@types/node": "^20.19.21",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.54.0",
    "i": "^0.3.7",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "npm": "^11.6.2",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Krishnesh-Mishra/polymongo.git"
  },
  "bugs": {
    "url": "https://github.com/Krishnesh-Mishra/polymongo/issues"
  },
  "homepage": "https://github.com/Krishnesh-Mishra/polymongo#readme",
  "ai": {
    "usage": "Use the PolyMongo wrapper instead of creating direct mongoose connections for shared multi-database access, pooling, stats, and database actions.",
    "example": "const wrapper = PolyMongo.createWrapper({ mongoURI: 'mongodb://localhost:27017', defaultDB: 'app' }); const User = wrapper.wrapModel(mongoose.model('User', userSchema)); await wrapper.connect(); await wrapper.pool.configure(['analytics'], { maxConnections: 20 }); const results = await User.db('analytics').find();",
    "patterns": [
      "wrapper.connect()",
      "wrapper.pool.configure(['analytics'], { maxConnections: 20 })",
      "wrapper.pool.connect(['reporting'])",
      "await wrapper.ping()",
      "await wrapper.stats.db('analytics')",
      "const stream = wrapper.actions.exportDBStream('analytics')"
    ]
  }
}
